function FlipFrame({ label, Comp, w, h }) {
  const [dark, setDark] = React.useState(true);
  return (
    <Frame label={label} onFlip={() => setDark(!dark)} dark={dark} w={w} h={h}>
      <Comp dark={dark} />
    </Frame>
  );
}

function Section({ title, note, children, gap = 40 }) {
  return (
    <div style={{ marginBottom: 80 }}>
      <div style={{ padding: '0 60px 28px', maxWidth: 1000 }}>
